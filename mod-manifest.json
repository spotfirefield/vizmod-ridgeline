{
  "apiVersion": "1.3",
  "version": "1.0.0",
  "name": "Joy Plot",
  "id": "com.spotfire.mods.joyplot",
  "icon": "icon.svg",
  "files": [
    "index.html",
    "build/main.js",
    "src/styles.css"
  ],
  "properties": [
    {
      "name": "ridgeMode",
      "type": "string",
      "defaultValue": "kde"
    },
    {
      "name": "overlapFactor",
      "type": "double",
      "defaultValue": 1.5
    },
    {
      "name": "bandwidth",
      "type": "double",
      "defaultValue": 0
    },
    {
      "name": "histBins",
      "type": "integer",
      "defaultValue": 20
    },
    {
      "name": "fillOpacity",
      "type": "double",
      "defaultValue": 0.75
    },
    {
      "name": "strokeWidth",
      "type": "double",
      "defaultValue": 1.5
    },
    {
      "name": "showDataPoints",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "ridge3D",
      "type": "boolean",
      "defaultValue": true
    },
    {
      "name": "showMean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "showMedian",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "showQuartiles",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "sortBy",
      "type": "string",
      "defaultValue": "value"
    },
    {
      "name": "trellisMode",
      "type": "string",
      "defaultValue": "rows"
    }
  ],
  "dataViewDefinition": {
    "colorAxis": {
      "mode": "dual",
      "dropTarget": {
        "icon": "Color",
        "description": "Color by {0}"
      }
    },
    "axes": [
      {
        "name": "Value",
        "mode": "continuous",
        "placement": "bottom",
        "dropTarget": {
          "icon": "XAxis3D",
          "description": "Distribution value: {0}"
        }
      },
      {
        "name": "Category",
        "mode": "categorical",
        "placement": "left",
        "dropTarget": {
          "icon": "YAxis3D",
          "description": "Group ridges by {0}"
        }
      },
      {
        "name": "Trellis by",
        "mode": "categorical",
        "placement": "none",
        "dropTarget": {
          "icon": "TrellisPanels",
          "description": "Split into panels by {0}"
        }
      },
      {
        "name": "MarkerBy",
        "mode": "categorical",
        "dropTarget": {
          "icon": "Color",
          "description": "One row per mark by {0} (use <baserowid()> for raw rows)"
        }
      }
    ]
  }
}
