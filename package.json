{
  "name": "spotfire-ridgeline",
  "version": "1.0.0",
  "description": "Ridgeline plot",
  "scripts": {
    "build:js": "webpack --mode production",
    "watch:js": "webpack --mode development --watch",
    "build": "npm run build:js && mods-sdk build",
    "start": "pushd \"%INIT_CWD%\" && node dev-server.js",
    "dev": "concurrently -n webpack,server -c blue,green \"npm:watch:js\" \"npm:start\""
  },
  "dependencies": {
    "d3": "^7.9.0"
  },
  "devDependencies": {
    "@spotfire/mods-dev-server": "^1.2.1",
    "@spotfire/mods-sdk": "^1.1.3",
    "concurrently": "^9.0.1",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4"
  }
}
